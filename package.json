{
  "name": "riverleaf-sql-formatter",
  "displayName": "Riverleaf SQL Formatter",
  "description": "Formats SQL in the river alignment style (keywords right-aligned to a common river).",
  "version": "0.0.1",
  "publisher": "nbluis",
  "author": {
    "name": "Eduardo Bohrer"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nbluis/riverleaf-sql-formatter.git"
  },
  "bugs": {
    "url": "https://github.com/nbluis/riverleaf-sql-formatter/issues"
  },
  "homepage": "https://github.com/nbluis/riverleaf-sql-formatter#readme",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Formatters"
  ],
  "keywords": [
    "sql",
    "formatter",
    "format",
    "sql formatter",
    "align",
    "river",
    "riverleaf"
  ],
  "icon": "assets/icon.png",
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:sql"
  ],
  "contributes": {
    "languages": [
      {
        "id": "sql",
        "aliases": [
          "SQL",
          "sql"
        ],
        "extensions": [
          ".sql"
        ]
      }
    ],
    "configuration": {
      "title": "Riverleaf SQL Formatter",
      "properties": {
        "riverleaf.keywordCase": {
          "type": "string",
          "enum": [
            "lower",
            "upper",
            "preserve"
          ],
          "default": "lower",
          "description": "Case for SQL keywords."
        },
        "riverleaf.indentSize": {
          "type": "number",
          "default": 2,
          "description": "Number of spaces per nesting level (parentheses/subqueries)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src test",
    "typecheck": "tsc --noEmit",
    "package": "vsce package"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^26.0.1",
    "@types/vscode": "^1.75.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "js-yaml": "^5.1.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}

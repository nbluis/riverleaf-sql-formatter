{
  "name": "riverleaf-sql-formatter",
  "version": "0.0.1",
  "description": "Format SQL in the river alignment style — clause keywords right-aligned to a common column, spaces only.",
  "license": "MIT",
  "author": {
    "name": "Eduardo Bohrer"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nbluis/riverleaf-sql-formatter.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/nbluis/riverleaf-sql-formatter/issues"
  },
  "homepage": "https://github.com/nbluis/riverleaf-sql-formatter#readme",
  "keywords": [
    "sql",
    "formatter",
    "format",
    "sql-formatter",
    "pretty-print",
    "align",
    "river",
    "riverleaf"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "riverleaf": "dist/cli.js"
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=16"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "build": "npm run clean && npm run build:js && npm run build:types",
    "build:js": "esbuild src/index.ts src/cli.ts --bundle --splitting --platform=node --format=esm --target=es2020 --sourcemap --outdir=dist",
    "build:types": "tsc -p tsconfig.build.json",
    "prepublishOnly": "node ../../scripts/sync-readme.mjs && npm run typecheck && npm run test && npm run build"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "js-yaml": "^5.2.1",
    "vitest": "^4.1.10"
  }
}
